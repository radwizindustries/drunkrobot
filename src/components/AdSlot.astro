---
interface Props { slot: string; }
const { slot } = Astro.props;
// Ads stay dark until BOTH are set. Flip PUBLIC_ADSENSE_ENABLED=true (and set
// PUBLIC_ADSENSE_CLIENT) in the environment to turn on display ads. The loader
// script in Base.astro is gated by the same flag, so nothing ships until then.
const enabled = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const show = enabled && !!client;
---
{show && (
  <aside class="ad-slot card-panel" data-ad-slot={slot} aria-label="Advertisement">
    <ins
      class="adsbygoogle"
      style="display:block;width:100%"
      data-ad-client={client}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
  </aside>
)}

<style>
  .ad-slot { min-height: 90px; display: flex; align-items: center; justify-content: center; color: var(--mute); }
</style>
