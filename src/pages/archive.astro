---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { sortByDate } from '../lib/comicNav';

const entries = await getCollection('comics');
const comics = sortByDate(entries.map((e) => e.data)).reverse(); // newest first
---

<Base title="Drunk Robot - Archive">
  <h1 class="display">The Complete Archive</h1>
  <p class="count">{comics.length} strips, 2011 to 2016</p>
  <ul class="grid">
    {comics.map((c) => (
      <li>
        <a href={`/comic/${c.slug}/`}>
          <span class="thumb"><img src={`/comics/${c.image}`} alt={c.title} loading="lazy" /></span>
          <span class="display t">{c.title}</span>
          <time datetime={c.date}>{c.date}</time>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 { margin: 1.5rem 0 0.25rem; font-size: 1.8rem; }
  .count { color: var(--muted); margin: 0 0 1.5rem; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.1em; }
  .grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .grid a { text-decoration: none; color: var(--text); display: block; }
  .thumb {
    display: block;
    border: 3px solid var(--red);
    background: #000;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .grid a:hover .thumb { border-color: var(--text); }
  .t { display: block; margin-top: 0.5rem; font-size: 0.9rem; }
  time { color: var(--muted); font-size: 0.75rem; }
</style>
