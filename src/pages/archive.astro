---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { sortByDate } from '../lib/comicNav';

const entries = await getCollection('comics');
const comics = sortByDate(entries.map((e) => e.data));

const byYear = new Map<string, typeof comics>();
for (const c of comics) {
  const year = c.date.slice(0, 4);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(c);
}
const years = [...byYear.keys()].sort().reverse(); // newest year first
---

<Base title="Drunk Robot - Archive">
  <h1 class="display">The Complete Archive</h1>
  <p class="readout">{comics.length} strips recovered · 2011 to 2016</p>
  <form class="archive-search" action="/search/" method="get" role="search">
    <input
      type="search"
      name="q"
      placeholder="Find that comic where..."
      aria-label="Search comics"
    />
    <button class="btn-panel display" type="submit">Search</button>
  </form>
  {years.map((year) => (
    <section aria-labelledby={`year-${year}`}>
      <h2 class="display year" id={`year-${year}`}>
        {year} <span class="readout">{byYear.get(year)!.length} {byYear.get(year)!.length === 1 ? 'strip' : 'strips'}</span>
      </h2>
      <ul class="grid">
        {byYear.get(year)!.map((c) => (
          <li>
            <a href={`/comic/${c.slug}/`}>
              <span class="thumb"><img src={`/comics/${c.image}`} alt={c.altText} loading="lazy" /></span>
              <span class="display t">{c.title}</span>
              <time class="mono" datetime={c.date}>{c.date}</time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  h1 { margin: 1.5rem 0 0.25rem; font-size: 1.8rem; color: var(--ink); }
  .year {
    font-size: 1.2rem;
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 0.4rem;
    margin: 2rem 0 1rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .archive-search {
    display: flex;
    gap: 0.6rem;
    margin: 1.25rem 0 0.5rem;
    max-width: 420px;
  }
  .archive-search input {
    flex: 1;
    min-width: 0;
    background: var(--surface);
    border: 1px solid var(--hairline);
    color: var(--text);
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
  }
  .archive-search input::placeholder { color: var(--muted); }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .grid a { text-decoration: none; color: var(--text); display: block; }
  .thumb {
    display: block;
    position: relative;
    z-index: 10; /* keep CRT scanlines off the strip art */
    border: 1px solid var(--edge);
    background: #fff;
    box-shadow: 4px 4px 0 var(--amber);
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .thumb img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .grid a:hover .thumb { box-shadow: 4px 4px 0 var(--amber); }
  .t { display: block; margin-top: 0.6rem; font-size: 0.9rem; color: var(--ink); }
  time { color: var(--muted); font-size: 0.72rem; }
  @media (max-width: 400px) {
    .grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
  }
</style>
