---
import { getCollection } from 'astro:content';
import ComicReader from '../components/ComicReader.astro';
import Base from '../layouts/Base.astro';
import { getNav, sortByDate } from '../lib/comicNav';

const entries = await getCollection('comics');
const comics = sortByDate(entries.map((e) => e.data));
const latest = comics[comics.length - 1];
const nav = getNav(comics, latest.slug);
const allSlugs = comics.map((c) => c.slug);
---

<Base
  title={`Drunk Robot - ${latest.title}`}
  description="Drunk Robot, a weekly webcomic skewering comics, sci-fi, and nerd culture. Ran 2011 to 2016, restored from the Internet Archive, publishing again."
  image={`/comics/${latest.image}`}
  preloadImage={nav.prev ? `/comics/${nav.prev.image}` : undefined}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Drunk Robot',
    url: new URL('/', Astro.site).toString(),
    description: 'A weekly webcomic skewering comics, sci-fi, and nerd culture. Ran 2011 to 2016, restored from the Internet Archive, publishing again.',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: new URL('/search/?q={search_term_string}', Astro.site).toString(),
      },
      'query-input': 'required name=search_term_string',
    },
  }}
>
  <p class="resume readout" id="resume" hidden>
    &gt; <a id="resume-link" href="/">Continue where you left off</a><span class="cursor" aria-hidden="true">_</span>
  </p>
  <ComicReader comic={latest} nav={nav} allSlugs={allSlugs} recordLast={false} />
</Base>

<script is:inline define:vars={{ latestSlug: latest.slug, allSlugs }}>
  // Offer to resume from the last strip read, if it isn't the one on screen.
  try {
    const last = localStorage.getItem('dr-last');
    if (last && last !== latestSlug && allSlugs.includes(last)) {
      const link = document.getElementById('resume-link');
      link.href = `/comic/${last}/`;
      document.getElementById('resume').hidden = false;
    }
  } catch (e) {}
</script>

<style>
  .resume {
    margin: 1.25rem 0 -0.5rem;
    color: var(--amber-text);
  }
  .resume a { color: var(--amber-text); }
  .cursor { animation: blink 1.1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
</style>
