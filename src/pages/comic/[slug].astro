---
import { getCollection } from 'astro:content';
import AdSlot from '../../components/AdSlot.astro';
import ComicReader from '../../components/ComicReader.astro';
import Base from '../../layouts/Base.astro';
import { getNav, sortByDate } from '../../lib/comicNav';
import { AUTHOR_SCHEMA, comicSeriesSchema } from '../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('comics');
  return entries.map((e) => ({ params: { slug: e.data.slug } }));
}

const { slug } = Astro.params;
const entries = await getCollection('comics');
const comics = sortByDate(entries.map((e) => e.data));
const comic = comics.find((c) => c.slug === slug)!;
const nav = getNav(comics, comic.slug);
const allSlugs = comics.map((c) => c.slug);

const number = String(nav.index + 1).padStart(3, '0');
// Meta description from the transcript's first line, minus the panel marker.
const description = comic.transcript
  .split('\n')[0]
  .replace(/^(Panel \d+|Single panel)\. /, '');
---

<Base
  title={`#${number} – ${comic.title} | Drunk Robot`}
  description={description}
  image={`/comics/${comic.image}`}
  type="article"
  preloadImage={nav.next ? `/comics/${nav.next.image}` : undefined}
  structuredData={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'ComicStory',
        name: comic.title,
        position: nav.index + 1,
        datePublished: comic.date,
        image: new URL(`/comics/${comic.image}`, Astro.site).toString(),
        url: Astro.url.toString(),
        text: comic.transcript,
        abstract: comic.altText,
        author: AUTHOR_SCHEMA,
        artist: { '@type': 'Person', name: 'Jeff Pina' },
        keywords: (comic.tags ?? []).join(', '),
        isPartOf: comicSeriesSchema(Astro.site),
      },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: 'Drunk Robot',
            item: new URL('/', Astro.site).toString(),
          },
          {
            '@type': 'ListItem',
            position: 2,
            name: 'Archive',
            item: new URL('/archive/', Astro.site).toString(),
          },
          { '@type': 'ListItem', position: 3, name: comic.title },
        ],
      },
    ],
  }}
>
  <ComicReader comic={comic} nav={nav} allSlugs={allSlugs} />
  <AdSlot slot="comic-below-strip" />
</Base>
