---
import Base from '../layouts/Base.astro';
---

<Base
  title="Search | Drunk Robot"
  description="Find that comic where... Search every Drunk Robot strip by dialogue, title, or tag."
>
  <h1 class="display">Find that comic where&hellip;</h1>
  <p class="readout">Full-text search over every strip's transcript</p>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <div id="search"></div>
  <noscript>
    <p>Search needs JavaScript. The <a href="/archive/">archive</a> lists every strip by year.</p>
  </noscript>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      // The Pagefind index is generated at build time; in `astro dev` it
      // doesn't exist yet.
      if (typeof PagefindUI === 'undefined') {
        document.getElementById('search').innerHTML =
          '<p class="readout">SEARCH INDEX OFFLINE (it is generated by the production build). ' +
          'Browse the <a href="/archive/">archive</a> instead.</p>';
        return;
      }
      new PagefindUI({ element: '#search', showImages: true, pageSize: 10 });
      // Honor /search/?q=... (used by the WebSite SearchAction schema).
      var q = new URLSearchParams(location.search).get('q');
      if (q) {
        var input = document.querySelector('#search input');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  </script>
</Base>

<style>
  h1 { margin: 1.5rem 0 0.25rem; font-size: 1.8rem; color: var(--ink); }
  p.readout { margin: 0 0 1.5rem; }
  #search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--link);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--hairline);
    --pagefind-ui-tag: var(--surface);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-image-border-radius: 0;
    --pagefind-ui-font: system-ui, -apple-system, sans-serif;
    margin-bottom: 2rem;
  }
</style>
