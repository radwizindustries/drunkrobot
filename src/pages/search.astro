---
import Base from '../layouts/Base.astro';
---

<Base
  title="Search | Drunk Robot"
  description="Find that comic where... Search every Drunk Robot strip by dialogue, title, or tag."
>
  <h1 class="pix" style="font-size:16px;margin:24px 0 6px">grep&gt; find that comic where&hellip;</h1>
  <p class="boot">full-text search over every strip's transcript</p>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <div id="search"></div>
  <noscript>
    <p>Search needs JavaScript. The <a href="/archive/">archive</a> lists every strip by year.</p>
  </noscript>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      // The Pagefind index is generated at build time; in `astro dev` it
      // doesn't exist yet.
      if (typeof PagefindUI === 'undefined') {
        document.getElementById('search').innerHTML =
          '<p class="boot">SEARCH INDEX OFFLINE (it is generated by the production build). ' +
          'Browse the <a href="/archive/">archive</a> instead.</p>';
        return;
      }
      new PagefindUI({ element: '#search', showImages: true, pageSize: 10 });
      // Honor /search/?q=... (used by the WebSite SearchAction schema).
      var q = new URLSearchParams(location.search).get('q');
      if (q) {
        var input = document.querySelector('#search input');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  </script>
  <script>
    import { isMatrixQuery } from '../lib/eastereggs';
    import { startMatrixRain } from '../scripts/site-eggs';
    function check(v: string) { if (isMatrixQuery(v)) startMatrixRain(); }
    // Deep link (?q=neo) and live typing into the Pagefind input.
    const q = new URLSearchParams(location.search).get('q');
    if (q) check(q);
    document.addEventListener('input', (e) => {
      const t = e.target as HTMLInputElement | null;
      if (t && t.matches('#search input')) check(t.value);
    });
  </script>
</Base>

<style>
  #search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--green);
    --pagefind-ui-text: var(--green);
    --pagefind-ui-background: var(--panel);
    --pagefind-ui-border: var(--edge);
    --pagefind-ui-tag: var(--panel);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-font: var(--font-body);
    margin: 12px 0 2rem;
  }
</style>
