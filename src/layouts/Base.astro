---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Absolute or site-relative image URL for social share cards (og:image / twitter:image). */
  image?: string;
  /** 'article' for a single comic's page, 'website' for index/archive/listing pages. */
  type?: 'website' | 'article';
  /** Optional JSON-LD structured data object, rendered as a single <script type="application/ld+json">. */
  structuredData?: Record<string, unknown>;
  /** Site-relative image URL to preload (the next strip a reader will likely open). */
  preloadImage?: string;
}

const {
  title,
  description = 'Drunk Robot, a weekly webcomic that ran 2011 to 2016.',
  image,
  type = 'website',
  structuredData,
  preloadImage,
} = Astro.props;
const path = Astro.url.pathname;
const canonicalURL = new URL(path, Astro.site);
const imageURL = image ? new URL(image, Astro.site).toString() : undefined;
// JSON.stringify doesn't escape "<", so a "</script>" inside any string
// value would break out of the script tag; escaping it keeps this safe
// regardless of what future data flows through structuredData.
const structuredDataJSON = structuredData
  ? JSON.stringify(structuredData).replace(/</g, '\\u003c')
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <script is:inline>
      // Theme before first paint: stored choice wins, else OS preference,
      // else dark ("lights off" is the house default).
      (function () {
        var stored;
        try { stored = localStorage.getItem('dr-theme'); } catch (e) {}
        var theme = stored === 'light' || stored === 'dark'
          ? stored
          : (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <link rel="alternate" type="application/rss+xml" title="Drunk Robot" href="/rss.xml" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} />}
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <meta property="og:site_name" content="Drunk Robot" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {imageURL && <meta property="og:image" content={imageURL} />}
    <meta name="twitter:card" content={imageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}

    {structuredDataJSON && (
      <script type="application/ld+json" set:html={structuredDataJSON} />
    )}

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YB0S160EP5"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-YB0S160EP5');
    </script>
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4622629903563464"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <div class="crt-overlay" aria-hidden="true"></div>
    <header class="site-header">
      <div class="wrap">
        <a class="logo display" href="/">DRUNK<em>ROBOT</em></a>
        <nav class="site-nav">
          <a href="/archive/" aria-current={path.startsWith('/archive') ? 'page' : undefined}>Archive</a>
          <a href="/search/" aria-current={path.startsWith('/search') ? 'page' : undefined}>Search</a>
          <a href="/about/" aria-current={path.startsWith('/about') ? 'page' : undefined}>About</a>
          <button class="theme-toggle mono" id="theme-toggle" type="button" aria-label="Toggle color theme">
            Lights
          </button>
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <div class="links">
          <a href="/archive/">Archive</a>
          <a href="/search/">Search</a>
          <a href="/about/">About</a>
          <a href="/rss.xml">RSS</a>
        </div>
        <p class="readout">
          DRUNK-ROBOT.COM · EST 2011 · <span class="lit">REBOOTED 2026</span>
        </p>
        <p>
          Drunk Robot ran weekly from 2011 to 2016 and publishes again.
          &copy; 2011&ndash;2026 Brian Powell &amp; Jeff Pina.
        </p>
      </div>
    </footer>
    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', function () {
        var next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('dr-theme', next); } catch (e) {}
      });

      // Typing b-o-o-p anywhere opens the maintenance terminal.
      // (A true Konami code would fight the arrow-key comic navigation.)
      (function () {
        var buffer = '';
        document.addEventListener('keydown', function (e) {
          var t = e.target;
          if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
          if (e.key.length !== 1) return;
          buffer = (buffer + e.key.toLowerCase()).slice(-4);
          if (buffer === 'boop') window.location.href = '/terminal/';
        });
      })();
    </script>
    <script>
      import '../scripts/site-eggs.ts';
    </script>
  </body>
</html>
